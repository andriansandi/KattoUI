# Copy this file to apps/web/.env and apps/api/.env and fill in your values.

# Clerk authentication
# Get these from https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# API URL used by the web app
VITE_API_URL=http://localhost:8791

# 32-byte key for encrypting provider API tokens at rest (AES-256-GCM).
# Worker secret only — set in .dev.vars (local) or via `wrangler secret put`.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=
