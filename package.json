{
	"name": "katto",
	"private": true,
	"type": "module",
	"version": "0.1.0",
	"description": "The Open Source AI Workspace built for Cloudflare.",
	"packageManager": "pnpm@9.15.0",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\" --names api,web --prefix-colors auto",
		"dev:web": "pnpm --filter @katto/web dev",
		"dev:api": "pnpm --filter @katto/api dev",
		"build": "pnpm -r build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "pnpm -r typecheck",
		"test": "vitest",
		"test:e2e": "playwright test",
		"migrate:encrypt-keys": "node scripts/migrate-encrypt-keys.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@playwright/test": "^1.49.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.1.0",
		"@testing-library/user-event": "^14.5.2",
		"@types/node": "^22.10.0",
		"@vitejs/plugin-react": "^4.4.0",
		"concurrently": "^9.1.0",
		"jsdom": "^25.0.1",
		"vitest": "^2.1.0",
		"wrangler": "^4.106.0"
	}
}
